{
  "name": "canton-dark",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "demo:phase1": "tsx scripts/run-demo-stack.ts phase1",
    "demo:phase1:seed": "tsx scripts/demo-seed.ts phase1-ready",
    "demo:phase2": "tsx scripts/run-demo-stack.ts phase2",
    "demo:phase2:seed": "tsx scripts/demo-seed.ts phase2-ready",
    "demo:phase3": "tsx scripts/run-demo-stack.ts phase3",
    "demo:phase3:seed": "tsx scripts/demo-seed.ts phase3-ready",
    "doctor:repo": "tsx scripts/repo-doctor.ts",
    "doctor:demo": "tsx scripts/demo-doctor.ts",
    "quality": "pnpm doctor:repo && pnpm lint && pnpm typecheck",
    "lint": "turbo run lint && eslint scripts/**/*.ts tests playwright.config.ts vitest.shared.ts && prettier --check .",
    "format": "prettier --write .",
    "typecheck": "turbo run typecheck && tsc --noEmit -p tsconfig.json",
    "test": "pnpm test:unit && pnpm test:property && pnpm test:contract && pnpm test:e2e && pnpm coverage:aggregate",
    "test:unit": "turbo run test:unit --concurrency=100%",
    "test:property": "FC_SEED=${FC_SEED:-424242} turbo run test:property --concurrency=1",
    "test:property:replay": "node scripts/replay-property.mjs",
    "test:contract": "turbo run test:contract --concurrency=1",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:phase1": "playwright test --grep @phase1",
    "test:e2e:phase2": "playwright test --grep @phase2",
    "test:e2e:phase3": "playwright test --grep @phase3",
    "test:daml": "tsx scripts/run-daml-tests.ts",
    "test:canton-integration": "tsx scripts/run-canton-integration.ts",
    "coverage:aggregate": "node scripts/verify-coverage.mjs",
    "unit-and-property": "pnpm test:unit && pnpm test:property",
    "contract-tests": "pnpm test:contract",
    "e2e-smoke": "pnpm doctor:demo && pnpm test:e2e:smoke",
    "sim:replay": "tsx scripts/sim-replay.ts",
    "sim:sweep": "tsx scripts/sim-sweep.ts",
    "nightly-simulation": "pnpm sim:sweep --seed-start 1 --seed-end 250",
    "ci:verify": "pnpm quality && pnpm unit-and-property && pnpm contract-tests && pnpm e2e-smoke && pnpm coverage:aggregate",
    "ci:full": "pnpm ci:verify && pnpm nightly-simulation && pnpm test:daml && pnpm test:canton-integration"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.59.1",
    "@types/node": "25.5.0",
    "@vitest/coverage-v8": "4.1.2",
    "eslint": "10.1.0",
    "fast-check": "4.6.0",
    "globals": "17.4.0",
    "jsdom": "29.0.1",
    "prettier": "3.8.1",
    "tsx": "4.21.0",
    "turbo": "2.9.3",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.0",
    "vite": "8.0.3",
    "vitest": "4.1.2"
  }
}
