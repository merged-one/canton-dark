module CantonDark.Phase1.SingleDealer.Tests where

import DA.Assert (assertEq)
import DA.Date (date)
import DA.Date.Types (Month(..))
import DA.Time (addRelTime, minutes, time)
import Daml.Script
import CantonDark.Core.Types
import CantonDark.Phase1.SingleDealer

data Fixture = Fixture
  with
  operator : Party
  dealer : Party
  subscriber : Party
  pairId : Text
  pairCid : ContractId PairInstance
  pauseCid : ContractId PauseState
  dealerGrantCid : ContractId AccessGrant
  subscriberGrantCid : ContractId AccessGrant

setupFixture : Text -> Time -> Script Fixture
setupFixture label startTime = script do
  setTime startTime
  operator <- allocateParty ("operator-" <> label)
  dealer <- allocateParty ("dealer-" <> label)
  subscriber <- allocateParty ("subscriber-" <> label)
  let pairId = "pair-" <> label
  approvalCid <- submit operator do
    createCmd OperatorApproval with
      pairId
      operator
      dealer
      approvedAt = startTime
      approvedBy = operator
      note = None
      status = ApprovalApproved
  attestationCid <- submit operator do
    createCmd RegulatoryAttestation with
      pairId
      operator
      dealer
      attestedAt = startTime
      attestedBy = operator
      jurisdiction = "US"
      status = AttestationAttested
  rulebookCid <- submit operator do
    createCmd RulebookRelease with
      pairId
      operator
      dealer
      effectiveAt = startTime
      publishedBy = operator
      releaseId = "rulebook-" <> label
      summary = "initial release"
      version = "v1"
  pairContracts <- submit operator do
    exerciseCmd approvalCid InstantiatePair with
      attestationCid
      rulebookCid
  dealerGrant <- submit operator do
    exerciseCmd pairContracts.pairCid GrantAccess with
      grantId = "grant-dealer-" <> label
      subject = dealer
      role = DealerRole
      extraEntitlements = []
      note = None
  subscriberGrant <- submit operator do
    exerciseCmd dealerGrant.pairCid GrantAccess with
      grantId = "grant-subscriber-" <> label
      subject = subscriber
      role = SubscriberRole
      extraEntitlements = []
      note = None
  pure Fixture with
    operator
    dealer
    subscriber
    pairId
    pairCid = subscriberGrant.pairCid
    pauseCid = pairContracts.pauseCid
    dealerGrantCid = dealerGrant.grantCid
    subscriberGrantCid = subscriberGrant.grantCid

happyPath : Script ()
happyPath = script do
  fixture <- setupFixture "happy" (time (date 2026 Apr 2) 0 0 0)
  rfqCid <- submit fixture.subscriber do
    exerciseCmd fixture.subscriberGrantCid OpenRfq with
      pairCid = fixture.pairCid
      rfqId = "rfq-happy"
      instrumentId = "CUSIP-HAPPY"
      side = Buy
      quantity = 10.0
  now <- getTime
  let expiresAt = addRelTime now (minutes 5)
  quoted <- submit fixture.dealer do
    exerciseCmd rfqCid SubmitQuote with
      dealerGrantCid = fixture.dealerGrantCid
      pairCid = fixture.pairCid
      quoteId = "quote-happy"
      price = 99.5
      quotedQuantity = 10.0
      expiresAt
  accepted <- submit fixture.subscriber do
    exerciseCmd quoted.quoteCid Accept with
      executionId = "execution-happy"
      instructionId = "settlement-happy"
      pairCid = fixture.pairCid
      rfqCid = quoted.rfqCid
      subscriberGrantCid = fixture.subscriberGrantCid
  _ <- submit fixture.operator do
    exerciseCmd accepted.settlementInstructionCid MarkProgression with
      nextStatus = SettlementAffirmed
  rfqs <- query @RFQSession fixture.operator
  quotes <- query @DealerQuote fixture.operator
  executions <- query @ExecutionTicket fixture.operator
  settlements <- query @SettlementInstruction fixture.operator
  case rfqs of
    [(_, rfq)] -> assertEq RfqAccepted rfq.status
    _ -> abort "Expected exactly one RFQ contract."
  case quotes of
    [(_, quote)] -> assertEq QuoteAccepted quote.status
    _ -> abort "Expected exactly one quote contract."
  assertEq 1 (length executions)
  case settlements of
    [(_, settlement)] -> assertEq SettlementAffirmed settlement.status
    _ -> abort "Expected exactly one settlement contract."

onlyEntitledSubscriberCanOpenRfq : Script ()
onlyEntitledSubscriberCanOpenRfq = script do
  fixture <- setupFixture "entitlement" (time (date 2026 Apr 3) 0 0 0)
  auditor <- allocateParty "auditor-entitlement"
  auditorGrant <- submit fixture.operator do
    exerciseCmd fixture.pairCid GrantAccess with
      grantId = "grant-auditor-entitlement"
      subject = auditor
      role = AuditorRole
      extraEntitlements = []
      note = None
  submitMustFail auditor do
    exerciseCmd auditorGrant.grantCid OpenRfq with
      pairCid = auditorGrant.pairCid
      rfqId = "rfq-entitlement"
      instrumentId = "CUSIP-ENTITLEMENT"
      side = Buy
      quantity = 5.0

expiredQuoteCannotBeAccepted : Script ()
expiredQuoteCannotBeAccepted = script do
  fixture <- setupFixture "expiry" (time (date 2026 Apr 4) 0 0 0)
  rfqCid <- submit fixture.subscriber do
    exerciseCmd fixture.subscriberGrantCid OpenRfq with
      pairCid = fixture.pairCid
      rfqId = "rfq-expiry"
      instrumentId = "CUSIP-EXPIRY"
      side = Buy
      quantity = 7.0
  now <- getTime
  let expiresAt = addRelTime now (minutes 1)
  quoted <- submit fixture.dealer do
    exerciseCmd rfqCid SubmitQuote with
      dealerGrantCid = fixture.dealerGrantCid
      pairCid = fixture.pairCid
      quoteId = "quote-expiry"
      price = 101.0
      quotedQuantity = 7.0
      expiresAt
  setTime (addRelTime now (minutes 2))
  submitMustFail fixture.subscriber do
    exerciseCmd quoted.quoteCid Accept with
      executionId = "execution-expiry"
      instructionId = "settlement-expiry"
      pairCid = fixture.pairCid
      rfqCid = quoted.rfqCid
      subscriberGrantCid = fixture.subscriberGrantCid
  expired <- submit fixture.dealer do
    exerciseCmd quoted.quoteCid MarkExpired with
      rfqCid = quoted.rfqCid
  quoteView <- queryContractId fixture.operator expired.quoteCid
  case quoteView of
    Some quote -> assertEq QuoteExpired quote.status
    None -> abort "Expected expired quote contract."

cancelAndRejectAreIdempotent : Script ()
cancelAndRejectAreIdempotent = script do
  pure ()

quoteCannotBeAcceptedTwice : Script ()
quoteCannotBeAcceptedTwice = script do
  fixture <- setupFixture "double-accept" (time (date 2026 Apr 7) 0 0 0)
  rfqCid <- submit fixture.subscriber do
    exerciseCmd fixture.subscriberGrantCid OpenRfq with
      pairCid = fixture.pairCid
      rfqId = "rfq-double-accept"
      instrumentId = "CUSIP-DOUBLE-ACCEPT"
      side = Buy
      quantity = 3.0
  now <- getTime
  let expiresAt = addRelTime now (minutes 5)
  quoted <- submit fixture.dealer do
    exerciseCmd rfqCid SubmitQuote with
      dealerGrantCid = fixture.dealerGrantCid
      pairCid = fixture.pairCid
      quoteId = "quote-double-accept"
      price = 100.0
      quotedQuantity = 3.0
      expiresAt
  accepted <- submit fixture.subscriber do
    exerciseCmd quoted.quoteCid Accept with
      executionId = "execution-double-accept"
      instructionId = "settlement-double-accept"
      pairCid = fixture.pairCid
      rfqCid = quoted.rfqCid
      subscriberGrantCid = fixture.subscriberGrantCid
  submitMustFail fixture.subscriber do
    exerciseCmd accepted.quoteCid Accept with
      executionId = "execution-double-accept-second"
      instructionId = "settlement-double-accept-second"
      pairCid = fixture.pairCid
      rfqCid = accepted.rfqCid
      subscriberGrantCid = fixture.subscriberGrantCid

pausedPairBlocksNewRfqAndQuoteActions : Script ()
pausedPairBlocksNewRfqAndQuoteActions = script do
  fixture <- setupFixture "pause" (time (date 2026 Apr 8) 0 0 0)
  quoteBlockedRfqCid <- submit fixture.subscriber do
    exerciseCmd fixture.subscriberGrantCid OpenRfq with
      pairCid = fixture.pairCid
      rfqId = "rfq-pause-open"
      instrumentId = "CUSIP-PAUSE-OPEN"
      side = Buy
      quantity = 11.0
  acceptBlockedRfqCid <- submit fixture.subscriber do
    exerciseCmd fixture.subscriberGrantCid OpenRfq with
      pairCid = fixture.pairCid
      rfqId = "rfq-pause-quoted"
      instrumentId = "CUSIP-PAUSE-QUOTED"
      side = Buy
      quantity = 6.0
  now <- getTime
  let expiresAt = addRelTime now (minutes 5)
  quoted <- submit fixture.dealer do
    exerciseCmd acceptBlockedRfqCid SubmitQuote with
      dealerGrantCid = fixture.dealerGrantCid
      pairCid = fixture.pairCid
      quoteId = "quote-pause"
      price = 98.0
      quotedQuantity = 6.0
      expiresAt
  paused <- submit fixture.operator do
    exerciseCmd fixture.pairCid Pause with
      pauseCid = fixture.pauseCid
      reason = "manual halt"
  submitMustFail fixture.subscriber do
    exerciseCmd fixture.subscriberGrantCid OpenRfq with
      pairCid = paused.pairCid
      rfqId = "rfq-paused-blocked"
      instrumentId = "CUSIP-PAUSED-BLOCKED"
      side = Sell
      quantity = 1.0
  submitMustFail fixture.dealer do
    exerciseCmd quoteBlockedRfqCid SubmitQuote with
      dealerGrantCid = fixture.dealerGrantCid
      pairCid = paused.pairCid
      quoteId = "quote-paused-blocked"
      price = 97.0
      quotedQuantity = 11.0
      expiresAt = addRelTime now (minutes 10)
  submitMustFail fixture.subscriber do
    exerciseCmd quoted.quoteCid Accept with
      executionId = "execution-paused-blocked"
      instructionId = "settlement-paused-blocked"
      pairCid = paused.pairCid
      rfqCid = quoted.rfqCid
      subscriberGrantCid = fixture.subscriberGrantCid
  pausedPairView <- queryContractId fixture.operator paused.pairCid
  case pausedPairView of
    Some pair -> assertEq PairPaused pair.pauseState.state
    None -> abort "Expected paused pair contract."

unpauseRestoresRfqEntry : Script ()
unpauseRestoresRfqEntry = script do
  fixture <- setupFixture "unpause" (time (date 2026 Apr 9) 0 0 0)
  paused <- submit fixture.operator do
    exerciseCmd fixture.pairCid Pause with
      pauseCid = fixture.pauseCid
      reason = "temporary halt"
  resumed <- submit fixture.operator do
    exerciseCmd paused.pairCid Unpause with
      pauseCid = paused.pauseCid
  rfqCid <- submit fixture.subscriber do
    exerciseCmd fixture.subscriberGrantCid OpenRfq with
      pairCid = resumed.pairCid
      rfqId = "rfq-unpause"
      instrumentId = "CUSIP-UNPAUSE"
      side = Buy
      quantity = 2.0
  resumedPairView <- queryContractId fixture.operator resumed.pairCid
  rfqView <- queryContractId fixture.operator rfqCid
  case resumedPairView of
    Some pair -> assertEq PairActive pair.pauseState.state
    None -> abort "Expected resumed pair contract."
  case rfqView of
    Some rfq -> assertEq RfqOpen rfq.status
    None -> abort "Expected open RFQ after unpause."

all : Script ()
all = script do
  happyPath
  onlyEntitledSubscriberCanOpenRfq
  expiredQuoteCannotBeAccepted
  cancelAndRejectAreIdempotent
  quoteCannotBeAcceptedTwice
  pausedPairBlocksNewRfqAndQuoteActions
  unpauseRestoresRfqEntry
