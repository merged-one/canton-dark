{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "test:unit": {
      "dependsOn": ["^test:unit"],
      "outputs": ["coverage/unit/**"]
    },
    "test:property": {
      "dependsOn": ["^test:property"],
      "outputs": []
    },
    "test:contract": {
      "dependsOn": ["^test:contract"],
      "outputs": []
    }
  }
}
