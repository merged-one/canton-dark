{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useUnknownInCatchVariables": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "verbatimModuleSyntax": true,
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@canton-dark/api-contracts": ["packages/api-contracts/src/index.ts"],
      "@canton-dark/adapters-canton": ["packages/adapters-canton/src/index.ts"],
      "@canton-dark/adapters-memory": ["packages/adapters-memory/src/index.ts"],
      "@canton-dark/app-services": ["packages/app-services/src/index.ts"],
      "@canton-dark/domain-core": ["packages/domain-core/src/index.ts"],
      "@canton-dark/query-models": ["packages/query-models/src/index.ts"],
      "@canton-dark/sim-harness": ["packages/sim-harness/src/index.ts"],
      "@canton-dark/telemetry": ["packages/telemetry/src/index.ts"],
      "@canton-dark/testkit": ["packages/testkit/src/index.ts"],
      "@canton-dark/ui-kit": ["packages/ui-kit/src/index.ts"],
      "@canton-dark/ui-sdk": ["packages/ui-sdk/src/index.ts"]
    }
  }
}
